{
  "schema": "framework_generico_integral_autosostenido",
  "schema_version": "1.0",
  "framework": {
    "name": "Framework Genérico",
    "version": "4.1.0",
    "edition": "Integral Autosostenido",
    "date": "2026-05-04",
    "status": "listo_para_implementacion",
    "self_contained": true,
    "depends_on_prior_versions": false,
    "recommended_destination_folder": "00_CONTROL_MAESTRO/",
    "purpose": "Permitir implementar el Framework Genérico V4.1.0 en proyectos nuevos sin depender de versiones anteriores."
  },
  "principles": [
    "juicio_humano",
    "etica_y_cuidado",
    "documentacion_activa",
    "escala_proporcional",
    "cierre_y_continuidad",
    "accesibilidad",
    "gobernanza",
    "archivo_historico"
  ],
  "needs_intake": {
    "questions": [
      "¿Qué problema, necesidad o deseo quieres atender?",
      "¿Quiénes son las personas o comunidades afectadas?",
      "¿Qué producto, resultado o cambio esperas lograr?",
      "¿El proyecto requiere investigación, creación, programación, enseñanza, gestión o integración?",
      "¿Usarás IA? ¿Para qué?",
      "¿Hay datos sensibles, comunidades vulnerables, menores, imágenes, voces, historias personales o patrimonio cultural?",
      "¿El resultado será privado, interno, académico, público o institucional?",
      "¿Cuánto tiempo durará el proyecto?",
      "¿Trabajará una persona, un equipo pequeño, una comunidad o una institución?",
      "¿Qué evidencia demostrará que hubo avance?",
      "¿Qué riesgos te preocupan?",
      "¿Quién debe poder retomar el trabajo después?"
    ],
    "classification_rules": [
      {
        "if": [
          "construir",
          "automatizar",
          "programar",
          "prototipar",
          "repositorio"
        ],
        "need_type": "tecnica",
        "activate": "Programador Humanista"
      },
      {
        "if": [
          "investigar",
          "fuentes",
          "evidencia",
          "analizar",
          "bibliografia"
        ],
        "need_type": "investigativa",
        "activate": "Investigador Transdisciplinario"
      },
      {
        "if": [
          "crear",
          "obra",
          "avatar",
          "galeria",
          "experiencia",
          "multimodal"
        ],
        "need_type": "creativa",
        "activate": "Artista Transdisciplinario"
      },
      {
        "if": [
          "integrar",
          "investigacion",
          "programacion",
          "creacion",
          "comunidad",
          "educacion"
        ],
        "need_type": "integrada",
        "activate": "Caleidoscopio"
      },
      {
        "if": [
          "institucionalizar",
          "escalar",
          "capacitar",
          "auditar",
          "politica"
        ],
        "need_type": "institucional",
        "activate": "N4 / C7"
      }
    ]
  },
  "levels": {
    "N1": {
      "name": "Mínimo controlado",
      "use_when": [
        "tarea breve",
        "bajo riesgo",
        "una persona",
        "producto simple"
      ],
      "minimum_documents": [
        "proposito",
        "producto",
        "cierre_breve"
      ],
      "avoid": [
        "manifest",
        "auditoria",
        "wiki_extensa",
        "automatizacion"
      ]
    },
    "N2": {
      "name": "Operativo",
      "use_when": [
        "varias fases",
        "equipo pequeño",
        "documentacion reusable",
        "seguimiento"
      ],
      "minimum_documents": [
        "brief",
        "README",
        "checklist",
        "decisiones_basicas",
        "cierre",
        "primer"
      ]
    },
    "N3": {
      "name": "Avanzado",
      "use_when": [
        "integracion",
        "IA sustantiva",
        "riesgos",
        "wiki",
        "archivo",
        "Caleidoscopio"
      ],
      "minimum_documents": [
        "README",
        "manifest",
        "Gates",
        "CHECKS",
        "changelog",
        "registro_decisiones",
        "wiki_sync",
        "archivo",
        "primer"
      ]
    },
    "N4": {
      "name": "Institucional",
      "use_when": [
        "adopcion formal",
        "politica",
        "auditoria",
        "capacitacion",
        "mantenimiento"
      ],
      "minimum_documents": [
        "gobernanza_formal",
        "RACI",
        "auditoria",
        "plan_capacitacion",
        "plan_mantenimiento",
        "release_institucional"
      ]
    }
  },
  "profiles": {
    "programador_humanista": {
      "version": "4.1.0-integral",
      "activate_when": [
        "codigo",
        "arquitectura tecnica",
        "repositorio",
        "automatizacion",
        "prototipo",
        "pruebas",
        "seguridad"
      ],
      "evidence": [
        "README tecnico",
        "codigo",
        "script",
        "tests",
        "release",
        "decisiones tecnicas"
      ],
      "risks": [
        "automatizacion prematura",
        "seguridad debil",
        "dependencias no documentadas",
        "datos expuestos"
      ]
    },
    "investigador_transdisciplinario": {
      "version": "4.1.0-integral",
      "activate_when": [
        "pregunta de investigacion",
        "fuentes",
        "evidencia",
        "metodologia",
        "bibliografia",
        "publicacion"
      ],
      "evidence": [
        "pregunta guia",
        "matriz de fuentes",
        "evidence ledger",
        "sintesis",
        "bibliografia",
        "marco conceptual"
      ],
      "risks": [
        "fuentes debiles",
        "sesgos",
        "extraccion epistemica",
        "IA sin verificacion"
      ]
    },
    "artista_transdisciplinario": {
      "version": "4.1.0-integral",
      "activate_when": [
        "obra",
        "narrativa",
        "avatar",
        "galeria",
        "curaduria",
        "memoria",
        "multimodalidad"
      ],
      "evidence": [
        "statement",
        "boceto",
        "prototipo",
        "obra",
        "ficha curatorial",
        "licencia"
      ],
      "risks": [
        "apropiacion cultural",
        "derechos de autor",
        "representacion inadecuada",
        "accesibilidad estetica debil"
      ]
    }
  },
  "kaleidoscope": {
    "definition": "Logica integradora emergente que combina perfiles para producir algo que no puede surgir desde un solo perfil.",
    "activation_question": "¿Qué emerge cuando programación, investigación y creación se transforman mutuamente bajo evidencia, ética, accesibilidad, documentación y transferencia?",
    "modes": {
      "C1": {
        "name": "Técnico-investigativo",
        "combination": [
          "Programador Humanista",
          "Investigador Transdisciplinario"
        ],
        "use": "apps de investigacion, dashboards, pipelines"
      },
      "C2": {
        "name": "Investigativo-creativo",
        "combination": [
          "Investigador Transdisciplinario",
          "Artista Transdisciplinario"
        ],
        "use": "investigacion-creacion, memoria, publicaciones multimodales"
      },
      "C3": {
        "name": "Creativo-técnico",
        "combination": [
          "Artista Transdisciplinario",
          "Programador Humanista"
        ],
        "use": "avatares, interfaces, galerias digitales"
      },
      "C4": {
        "name": "Integral",
        "combination": [
          "Programador Humanista",
          "Investigador Transdisciplinario",
          "Artista Transdisciplinario"
        ],
        "use": "AVAT, REA multimodal, ecosistemas agenticos"
      },
      "C5": {
        "name": "Pedagógico",
        "combination": [
          "perfiles segun necesidad"
        ],
        "use": "cursos, modulos, OVAT"
      },
      "C6": {
        "name": "Comunitario",
        "combination": [
          "comunidad",
          "perfiles segun necesidad"
        ],
        "use": "archivo vivo, memoria territorial"
      },
      "C7": {
        "name": "Institucional",
        "combination": [
          "tres perfiles",
          "gobernanza"
        ],
        "use": "laboratorios, programas, politicas, manuales"
      }
    }
  },
  "workflow": [
    {
      "phase": "activacion",
      "steps": [
        "describir necesidad",
        "identificar contexto",
        "determinar nivel",
        "activar perfil",
        "definir producto",
        "identificar riesgos"
      ]
    },
    {
      "phase": "diseno",
      "steps": [
        "crear brief",
        "definir alcance",
        "seleccionar metodologia",
        "definir evidencia",
        "definir roles humanos e IA"
      ]
    },
    {
      "phase": "produccion",
      "steps": [
        "crear producto",
        "documentar decisiones",
        "registrar uso de IA",
        "revisar accesibilidad",
        "revisar etica",
        "aplicar CHECKS"
      ]
    },
    {
      "phase": "evaluacion",
      "steps": [
        "aplicar Gates",
        "revisar evidencia",
        "validar humanamente",
        "identificar riesgos",
        "decidir siguiente estado"
      ]
    },
    {
      "phase": "cierre",
      "steps": [
        "crear cierre",
        "actualizar changelog",
        "actualizar decisiones",
        "actualizar primer",
        "actualizar wiki si aplica",
        "archivar si corresponde"
      ]
    }
  ],
  "gates": [
    {
      "id": "G1",
      "name": "Propósito",
      "question": "¿Está claro por qué existe el proyecto?"
    },
    {
      "id": "G2",
      "name": "Ubicación",
      "question": "¿Dónde vive el trabajo dentro del sistema?"
    },
    {
      "id": "G3",
      "name": "Perfil / Caleidoscopio",
      "question": "¿Se activó el lente correcto?"
    },
    {
      "id": "G4",
      "name": "Metodología",
      "question": "¿Hay ruta de trabajo?"
    },
    {
      "id": "G5",
      "name": "Evidencia",
      "question": "¿Qué demuestra el avance?"
    },
    {
      "id": "G6",
      "name": "IA responsable",
      "question": "¿Cómo se usó y revisó IA?"
    },
    {
      "id": "G7",
      "name": "Ética y derechos",
      "question": "¿Hay riesgos humanos, culturales o legales?"
    },
    {
      "id": "G8",
      "name": "Accesibilidad",
      "question": "¿Puede usarse por audiencias diversas?"
    },
    {
      "id": "G9",
      "name": "Calidad",
      "question": "¿Cumple criterios técnicos, investigativos o creativos?"
    },
    {
      "id": "G10",
      "name": "Documentación",
      "question": "¿Quedó documentado?"
    },
    {
      "id": "G11",
      "name": "Wiki / transferencia",
      "question": "¿Debe traducirse a guía humana?"
    },
    {
      "id": "G12",
      "name": "Archivo",
      "question": "¿Debe preservarse?"
    },
    {
      "id": "G13",
      "name": "Continuidad",
      "question": "¿Alguien puede retomarlo?"
    },
    {
      "id": "G14",
      "name": "Estabilización",
      "question": "¿Puede declararse versión estable?"
    }
  ],
  "checks": {
    "inicio": [
      "proposito claro",
      "usuario/comunidad identificada",
      "producto esperado",
      "nivel seleccionado",
      "perfil activado",
      "riesgos iniciales",
      "evidencia minima",
      "uso de IA",
      "espacio de trabajo"
    ],
    "produccion": [
      "evidencia producida",
      "decisiones documentadas",
      "etica revisada",
      "accesibilidad revisada",
      "derechos revisados",
      "IA validada",
      "criterios de calidad",
      "pendientes identificados"
    ],
    "cierre": [
      "producto con version y estado",
      "cierre/resumen",
      "changelog si aplica",
      "registro de decisiones si aplica",
      "wiki si aplica",
      "archivo si aplica",
      "primer si aplica",
      "proxima accion"
    ]
  },
  "templates": {
    "brief": {
      "fields": [
        "Nombre",
        "Fecha",
        "Responsable",
        "Necesidad",
        "Contexto",
        "Personas afectadas",
        "Nivel N1-N4",
        "Perfil/Caleidoscopio",
        "Producto esperado",
        "Evidencia minima",
        "Riesgos",
        "Uso de IA",
        "Criterios de cierre",
        "Proximo paso"
      ]
    },
    "decision_record": {
      "fields": [
        "ID",
        "Fecha",
        "Decision",
        "Justificacion",
        "Tipo de cambio",
        "Impacto",
        "Riesgo",
        "Documentos afectados",
        "Version afectada",
        "Estado",
        "Recomendacion de continuidad"
      ]
    },
    "session_closure": {
      "fields": [
        "Fecha",
        "Objetivo",
        "Nivel",
        "Perfil/Caleidoscopio",
        "Producto generado",
        "Cartapacio destino",
        "Decisiones",
        "Riesgos",
        "CHECKS aplicados",
        "Documentos actualizados",
        "Proxima accion"
      ]
    },
    "continuity_primer": {
      "fields": [
        "Estado actual",
        "Que abrir primero",
        "Decisiones vigentes",
        "Riesgos pendientes",
        "Proximo paso",
        "Prompt de reactivacion"
      ]
    }
  },
  "repository_structure_suggested": [
    "00_CONTROL_MAESTRO/",
    "01_FUNDAMENTO_FILOSOFICO/",
    "02_ARQUITECTURA_CONCEPTUAL/",
    "03_METODOLOGIA_Y_FLUJO_DE_TRABAJO/",
    "04_GOBERNANZA_ETICA_Y_RIESGOS/",
    "05_COMPETENCIAS_Y_PERFILES/",
    "06_PASTILLAS_MODULARES/",
    "07_PLANTILLAS_Y_MODELOS/",
    "08_CURSOS_PROGRAMAS_Y_TRAYECTORIAS/",
    "09_IA_AGENTES_Y_COPILOTOS/",
    "10_REPOSITORIOS_Y_FLUJO_TECNICO/",
    "11_MULTIMODALIDAD_Y_PUBLICACION/",
    "12_DISENO_INSTRUCCIONAL_UNIVERSAL/",
    "13_INVESTIGACION_Y_EVIDENCIA/",
    "14_COMUNIDAD_TRANSFERENCIA_Y_ESCALAMIENTO/",
    "15_EVALUACION_CALIDAD_Y_AUDITORIA/",
    "16_SEGURIDAD_PRIVACIDAD_Y_DATOS/",
    "17_INTERNACIONALIZACION_LOCALIZACION/",
    "18_DOCUMENTACION_ACTIVA/",
    "19_IMPLEMENTACION_Y_DESPLIEGUE/",
    "20_MANTENIMIENTO_Y_EVOLUCION/",
    "21_WIKI_DOCUMENTACION_HUMANA/",
    "99_ARCHIVO_HISTORICO/"
  ],
  "activation_prompt": "Actúa como Orquestador Humano-IA del Framework Genérico V4.1.0 Integral Autosostenido. Antes de producir cualquier solución, identifica necesidades del usuario, determina nivel N1-N4, perfil activo o modo Caleidoscopio C1-C7, alcance, riesgos, documentos mínimos, Gates/CHECKS, producto esperado y ruta de trabajo.",
  "success_criteria": [
    "necesidad identificada",
    "nivel N1-N4 justificado",
    "perfil o Caleidoscopio activado",
    "evidencia producida",
    "riesgos revisados",
    "uso de IA documentado",
    "decisiones registradas",
    "documentos ubicados",
    "continuidad preparada"
  ]
}